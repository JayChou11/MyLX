<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysStudentMapper">

    <resultMap type="SysStudent" id="SysStudentResult">
        <id     property="studentId"   column="student_id"   />
        <result property="studentNo"   column="student_no"   />
        <result property="studentName" column="student_name" />
        <result property="idCard"      column="id_card"      />
        <result property="age"         column="age"          />
        <result property="gender"      column="gender"       />
        <result property="classId"     column="class_id"     />
        <result property="grade"       column="grade"        />
        <result property="className"   column="class_name"   />
        <result property="photo"       column="photo"        />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"  column="create_time"  />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"  column="update_time"  />
        <result property="remark"      column="remark"       />
    </resultMap>

    <sql id="selectStudentVo">
        select s.student_id, s.student_no, s.student_name, s.id_card, s.age, s.gender,
               s.class_id, c.grade, c.class_name, s.photo,
               s.create_by, s.create_time, s.update_by, s.update_time, s.remark
        from sys_student s
        left join sys_class c on s.class_id = c.class_id
    </sql>

    <select id="selectStudentByStudentId" parameterType="Long" resultMap="SysStudentResult">
        <include refid="selectStudentVo"/>
        where s.student_id = #{studentId}
    </select>

    <select id="selectStudentList" parameterType="SysStudent" resultMap="SysStudentResult">
        <include refid="selectStudentVo"/>
        <where>
            <if test="studentNo != null and studentNo != ''">
                and s.student_no like concat('%', #{studentNo}, '%')
            </if>
            <if test="studentName != null and studentName != ''">
                and s.student_name like concat('%', #{studentName}, '%')
            </if>
            <if test="idCard != null and idCard != ''">
                and s.id_card like concat('%', #{idCard}, '%')
            </if>
            <if test="gender != null and gender != ''">
                and s.gender = #{gender}
            </if>
            <if test="classId != null">
                and s.class_id = #{classId}
            </if>
            <if test="grade != null and grade != ''">
                and c.grade like concat('%', #{grade}, '%')
            </if>
            <if test="className != null and className != ''">
                and c.class_name like concat('%', #{className}, '%')
            </if>
            <if test="params.beginTime != null and params.beginTime != ''">
                and date_format(s.create_time,'%Y%m%d') &gt;= date_format(#{params.beginTime},'%Y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                and date_format(s.create_time,'%Y%m%d') &lt;= date_format(#{params.endTime},'%Y%m%d')
            </if>
        </where>
        order by s.student_id desc
    </select>

    <select id="selectStudentListByIds" resultMap="SysStudentResult">
        <include refid="selectStudentVo"/>
        where s.student_id in
        <foreach item="studentId" collection="array" open="(" separator="," close=")">
            #{studentId}
        </foreach>
        order by s.student_id desc
    </select>

    <!-- 以班级表为主表，保证没有学生的班级也能出现在统计结果中 -->
    <select id="selectStudentClassStatList" resultType="com.ruoyi.system.domain.vo.SysStudentClassStat">
        select c.grade,
               c.class_name as className,
               c.class_id as classId,
               c.max_count as maxCount,
               count(s.student_id) as studentCount,
               sum(case when s.gender = '0' then 1 else 0 end) as maleCount,
               sum(case when s.gender = '1' then 1 else 0 end) as femaleCount,
               sum(case when s.gender = '2' then 1 else 0 end) as unknownCount
        from sys_class c
        left join sys_student s on s.class_id = c.class_id
        group by c.grade, c.class_name, c.class_id, c.max_count
        order by c.grade asc, c.class_name asc
    </select>

    <update id="transferStudentClass" parameterType="com.ruoyi.system.domain.vo.SysStudentTransferDto">
        update sys_student
        set class_id = #{classId},
            <if test="remark != null and remark != ''">
                remark = #{remark},
            </if>
            update_by = #{updateBy},
            update_time = sysdate()
        where student_id in
        <foreach item="studentId" collection="studentIds" open="(" separator="," close=")">
            #{studentId}
        </foreach>
    </update>

    <select id="selectStudentByStudentNo" parameterType="String" resultMap="SysStudentResult">
        <include refid="selectStudentVo"/>
        where s.student_no = #{studentNo}
        limit 1
    </select>

    <select id="selectStudentByIdCard" parameterType="String" resultMap="SysStudentResult">
        <include refid="selectStudentVo"/>
        where s.id_card = #{idCard}
        limit 1
    </select>

    <insert id="insertStudent" parameterType="SysStudent" useGeneratedKeys="true" keyProperty="studentId">
        insert into sys_student(
            <if test="studentNo != null and studentNo != ''">student_no,</if>
            <if test="studentName != null and studentName != ''">student_name,</if>
            <if test="idCard != null and idCard != ''">id_card,</if>
            <if test="age != null">age,</if>
            <if test="gender != null and gender != ''">gender,</if>
            <if test="classId != null">class_id,</if>
            <if test="photo != null and photo != ''">photo,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        ) values (
            <if test="studentNo != null and studentNo != ''">#{studentNo},</if>
            <if test="studentName != null and studentName != ''">#{studentName},</if>
            <if test="idCard != null and idCard != ''">#{idCard},</if>
            <if test="age != null">#{age},</if>
            <if test="gender != null and gender != ''">#{gender},</if>
            <if test="classId != null">#{classId},</if>
            <if test="photo != null and photo != ''">#{photo},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>

    <update id="updateStudent" parameterType="SysStudent">
        update sys_student
        <set>
            <if test="studentNo != null and studentNo != ''">student_no = #{studentNo},</if>
            <if test="studentName != null and studentName != ''">student_name = #{studentName},</if>
            <if test="idCard != null and idCard != ''">id_card = #{idCard},</if>
            <if test="age != null">age = #{age},</if>
            <if test="gender != null and gender != ''">gender = #{gender},</if>
            <if test="classId != null">class_id = #{classId},</if>
            <if test="photo != null">photo = #{photo},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where student_id = #{studentId}
    </update>

    <delete id="deleteStudentByStudentId" parameterType="Long">
        delete from sys_student where student_id = #{studentId}
    </delete>

    <delete id="deleteStudentByStudentIds" parameterType="Long">
        delete from sys_student where student_id in
        <foreach item="studentId" collection="array" open="(" separator="," close=")">
            #{studentId}
        </foreach>
    </delete>

    <update id="upgradeStudentClassByClassId">
        update sys_student
        set class_id = #{newClassId},
            update_by = #{updateBy},
            update_time = sysdate()
        where class_id = #{oldClassId}
    </update>

    <delete id="deleteStudentByClassIds">
        delete from sys_student where class_id in
        <foreach item="classId" collection="classIds" open="(" separator="," close=")">
            #{classId}
        </foreach>
    </delete>

</mapper>
